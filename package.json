{
  "name": "kasa360",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_OFFLINE=1 expo start",
    "android": "EXPO_OFFLINE=1 expo start --android",
    "ios": "EXPO_OFFLINE=1 expo start --ios",
    "web": "EXPO_OFFLINE=1 expo start --web",
    "typecheck": "tsc --noEmit",
    "build:android:preview": "eas build -p android --profile preview",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:ios:testflight": "eas build -p ios --profile testflight",
    "submit:ios:testflight": "eas submit -p ios --profile testflight --latest"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans": "^0.2.3",
    "@opentelemetry/api": "^1.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.36",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.12",
    "typescript": "~5.9.2"
  },
  "private": true
}
